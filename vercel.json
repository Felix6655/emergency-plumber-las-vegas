{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://*.emergentagent.com https://*.preview.emergentagent.com https://*.emergent.ai https://*.preview.emergent.ai;"
        }
      ]
    }
  ]
}
